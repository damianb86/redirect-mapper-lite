COMPOSE_PROJECT_NAME=redirect-mapper-lite
SHARED_DOCKER_NETWORK=shared_apps
APP_ENV=development

SHOPIFY_API_KEY=replace-with-shopify-client-id
SHOPIFY_API_SECRET=replace-with-shopify-client-secret
SHOPIFY_BILLING_TEST=false
APP_HOST=redirect-mapper-lite.yourdomain.com
SHOPIFY_APP_URL=
PROD_SHOPIFY_APP_URL=https://redirect-mapper-lite.yourdomain.com
DEV_SHOPIFY_APP_URL=
SCOPES=read_products,write_products,write_online_store_navigation

APP_DB_NAME=redirect_mapper_lite
APP_DB_USER=redirect_mapper_lite
APP_DB_PASSWORD=replace-with-app-db-password
DEV_DATABASE_URL=file:./dev.sqlite
DATABASE_URL=postgresql://redirect_mapper_lite:replace-with-app-db-password@postgres:5432/redirect_mapper_lite?schema=public&connection_limit=3

# Cloudflare Email Routing receives contact@zuam.dev and forwards it to Gmail.
# Outbound app email should use Resend SMTP from the verified zuam.dev domain.
CONTACT_EMAIL=contact@zuam.dev
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=resend
EMAIL_PASS=
EMAIL_FROM=noreply@zuam.dev
EMAIL_FROM_NAME="Zuam RedirectPulse"
EMAIL_REPLY_TO=contact@zuam.dev

OPENAI_API_KEY=
AI_WIZARD_DISABLED=false
AI_WIZARD_MODEL=gpt-5-mini
AI_WIZARD_FALLBACK_MODEL=gpt-5.5
AI_WIZARD_CONFIDENCE_THRESHOLD=0.55
AI_WIZARD_REASONING_EFFORT=low

NODE_OPTIONS=--max-old-space-size=128

APP_NAME=redirect-mapper-lite
LOG_LEVEL=info
LOG_DIR=/app/logs
LOG_TO_FILE=true
APP_LOG_DIR=./logs
